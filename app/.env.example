# Claude API key — get yours at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# GitHub Personal Access Token — needs 'repo' scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Your GitHub username or organization name
GITHUB_OWNER=your_github_username

# Repository name (the one that serves your GitHub Pages site)
GITHUB_REPO=MPC

# Branch to open pull requests against (usually master or main)
GITHUB_BASE_BRANCH=master

# Time to run the daily generation (UTC, 24-hour clock)
# Default: 08:00 UTC
RUN_HOUR=8
RUN_MINUTE=0
